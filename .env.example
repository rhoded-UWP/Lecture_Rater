# Lecture Coach — API keys.
# Copy this file to `.env` (same folder) and paste in the keys you have.
# `npm start` loads .env automatically. NEVER commit .env — it is gitignored.
# On Render, set these same names as environment variables instead.
# A missing key just means that provider shows "no key" in the dev panel;
# everything else keeps working.

# OpenAI — Whisper transcription (platform.openai.com → API keys)
OPENAI_API_KEY=

# Anthropic — Claude fact-check + deep analysis (console.anthropic.com → API keys)
ANTHROPIC_API_KEY=

# AssemblyAI — alternative transcription (assemblyai.com → dashboard → API key)
ASSEMBLYAI_API_KEY=

# DeepSeek — budget analysis models (platform.deepseek.com → API keys)
DEEPSEEK_API_KEY=

# Moonshot AI — Kimi analysis models (platform.moonshot.ai → API keys)
MOONSHOT_API_KEY=
